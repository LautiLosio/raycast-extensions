{
  "name": "quick-alarm-timer",
  "title": "Quick Alarm Timer",
  "description": "Create a quick alarm or timer directly from Raycast root search.",
  "icon": "extension-icon.png",
  "author": "thomas",
  "license": "MIT",
  "categories": [
    "Productivity"
  ],
  "platforms": [
    "macOS"
  ],
  "commands": [
    {
      "name": "set-alarm",
      "title": "Set Alarm",
      "description": "Set an alarm for a specific time of day.",
      "mode": "no-view",
      "keywords": [
        "alarm",
        "clock",
        "wake",
        "tod"
      ],
      "arguments": [
        {
          "name": "time",
          "type": "text",
          "placeholder": "7:30 am or 19:30",
          "required": true
        }
      ]
    },
    {
      "name": "start-timer",
      "title": "Start Timer",
      "description": "Start a timer for a duration.",
      "mode": "no-view",
      "keywords": [
        "timer",
        "countdown",
        "duration"
      ],
      "arguments": [
        {
          "name": "duration",
          "type": "text",
          "placeholder": "10m, 90s, 1h 30m",
          "required": true
        }
      ]
    },
    {
      "name": "manage-schedules",
      "title": "Manage Alarms & Timers",
      "description": "View, edit, and delete scheduled alarms and timers.",
      "mode": "view",
      "keywords": [
        "manage",
        "scheduled",
        "alarms",
        "timers"
      ]
    }
  ],
  "scripts": {
    "dev": "ray develop",
    "build": "ray build",
    "lint": "ray lint",
    "fix-lint": "ray lint --fix"
  },
  "dependencies": {
    "@raycast/api": "^1.104.13"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3"
  }
}
